APP_NAME="Auntie Kash Kids Academy"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database (Railway MySQL — auto-filled by Railway) ─────────────────────
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# ─── Session & Cache ────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=10080
CACHE_STORE=database
QUEUE_CONNECTION=database

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Resend ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=noreply@auntiekashkids.com
MAIL_FROM_NAME="Auntie Kash Kids Academy"
TEAM_NOTIFICATION_EMAIL=hello@auntiekashkids.com

# ─── JWT / Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=generate_with_php_artisan_key_generate
